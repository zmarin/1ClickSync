{
  "name": "1clicksync",
  "version": "0.1.0",
  "description": "1ClickSync — Zoho integration generator for developer-owned apps and sites.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "test:smoke": "tsx src/tests/smoke.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/session": "^10.9.0",
    "@fastify/static": "^7.0.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.12.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.12.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
