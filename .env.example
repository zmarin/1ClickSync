# ── Environment ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://oneclicksync:changeme@postgres:5432/oneclicksync
DB_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Security ─────────────────────────────────────────
# Session cookie secret (min 16 chars)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# JWT signing secret (min 16 chars, use different from SESSION_SECRET in prod)
JWT_SECRET=change-me-to-a-different-long-random-string
# AES-256-GCM encryption key (exactly 64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Zoho OAuth ───────────────────────────────────────
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:3000/api/auth/zoho/callback

# ── Google OAuth (optional) ──────────────────────────
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Stripe (optional) ───────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_AGENCY_PRICE_ID=price_...
# STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/app?checkout=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/app?checkout=cancel
# STRIPE_PORTAL_RETURN_URL=http://localhost:3000/app?billing=portal

# ── Email (optional — falls back to console in dev) ──
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=1ClickSync <noreply@1clicksync.com>

# ── Reverse proxy ───────────────────────────────────
# Set to true if behind nginx/cloudflare for correct IP rate limiting
TRUST_PROXY=false
